# 复制为 .env 后按需填写。compose 用它做变量替换并注入 janus 容器。

# ── Home Assistant ──────────────────────────────────────────
# 完成 HA 首次设置后,在 HA → 头像 → 安全 → 长期访问令牌 创建,填这里。
# 留空时 Janus 会打印引导并干净退出(栈其余部分照常起);填好后 `docker compose up -d janus`。
GATEKEEPER_HA_TOKEN=

# ── 本地模型(Ollama)─────────────────────────────────────────
# 必须支持 OpenAI 工具调用(Janus 解析器强制 tool_choice,不支持会按请求 fail-closed)。
# qwen2.5:3b 小而快、廉价硬件可跑;求质量可换 qwen2.5:7b(更大更慢)。
JANUS_LOCAL_MODEL=qwen2.5:3b

# ── 可选:危险操作第二因子 PIN ───────────────────────────────
# 设置后,开锁/开门等危险操作的确认需带此 PIN;留空=关闭。
JANUS_DANGEROUS_PIN=
